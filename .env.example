# Server Configuration
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/einvoicing_db

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# ZATCA E-Invoicing Configuration
# API Base URL (Fatoortak ZATCA Gateway)
ZATCA_API_URL=https://bw.fatoortak.sa

# Environment: sandbox, simulation, or production
ZATCA_ENVIRONMENT=simulation

# OAuth2 Token Endpoint
ZATCA_TOKEN_URL=https://bw.fatoortak.sa/token

# OAuth2 Client Credentials
# For simulation/production, use your assigned credentials
ZATCA_CLIENT_ID=AdminClient001
ZATCA_CLIENT_SECRET=Admin@Fatoortak001

# OAuth2 Scope (zatca.admin for full access)
ZATCA_SCOPES=zatca.admin

# Swagger UI for API documentation: https://bw.fatoortak.sa/FatoorahEinvoice/index.html

# Encryption (MUST be exactly 32 characters for AES-256)
ENCRYPTION_KEY=12345678901234567890123456789012

# File Storage (AWS S3)
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Email Service (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Stripe Configuration (existing)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# Moyasar Payment Gateway
MOYASAR_SECRET_KEY=sk_test_your_secret_key
MOYASAR_PUBLISHABLE_KEY=pk_test_your_publishable_key
MOYASAR_WEBHOOK_SECRET=your_webhook_secret
